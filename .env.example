# Copy this file to .env and adjust as needed.
# docker-compose reads these automatically. NEVER commit a real .env file.

# ----- PostgreSQL -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=inventory
POSTGRES_PORT=5432

# ----- Backend -----
# Port the backend is exposed on (host side).
BACKEND_PORT=8000
# Comma-separated allowed CORS origins, or * for all.
# In production set this to your deployed frontend URL, e.g.
# CORS_ORIGINS=https://your-frontend.vercel.app
CORS_ORIGINS=*

# ----- LLM analytics (OpenRouter) -----
# Get a key at https://openrouter.ai/keys. Leave empty to disable the
# "Analytics" dashboard feature (the rest of the app works without it).
OPENROUTER_API_KEY=
# Any model id from https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.0-flash

# ----- Frontend -----
# Host port the frontend (nginx) is served on.
FRONTEND_PORT=3000
